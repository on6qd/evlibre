{
  "supervisionUrls": ["ws://host.docker.internal:9090/ocpp/demo-tenant"],
  "supervisionUrlDistribution": "round-robin",
  "stationTemplateUrls": [
    {
      "file": "evlibre-16.json",
      "numberOfStations": 10
    }
  ],
  "log": {
    "statisticsInterval": 60,
    "level": "info",
    "console": true
  },
  "performanceStorage": {
    "enabled": false,
    "type": "none"
  },
  "worker": {
    "processType": "workerSet",
    "startDelay": 500,
    "elementsPerWorker": "auto",
    "elementAddDelay": 500
  },
  "uiServer": {
    "enabled": false
  }
}
